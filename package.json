{
  "name": "my-portofolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/npm-run-all2/bin/run-p/index.js type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@vercel/analytics": "^1.6.1",
    "aos": "^2.3.4",
    "axios": "^1.12.2",
    "bootstrap": "^5.3.8",
    "boxicons": "^2.1.4",
    "pinia": "^3.0.3",
    "vue": "^3.5.32",
    "vue-router": "^4.5.1",
    "vue-sweetalert2": "^5.0.11"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "^8.0.4",
    "typescript": "~5.9.3",
    "eslint": "^9.37.0",
    "eslint-plugin-vue": "^10.5.0",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1",
    "npm-run-all2": "^8.0.4"
  }
}